{
  "name": "bug-horn",
  "displayName": "Bug Horn",
  "description": "Plays a 'bug horn' sound whenever there's an error in the terminal",
  "version": "1.0.0",
  "publisher": "ayushsharaf",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayush-sharaf/play-sound.git"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
      "activationEvents": [
      "onStartupFinished",
      "onCommand:bugHorn.toggle",
      "onCommand:bugHorn.testSound",
      "onCommand:bugHorn.addSound",
      "onCommand:bugHorn.openSoundsFolder"
    ],
    "main": "./extension.js",
  
    "contributes": {
      "configuration": {
        "type": "object",
        "title": "Bug Horn Error",
        "properties": {
          "bugHorn.enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable/disable the terminal sound on terminal errors"
          },
          "bugHorn.volume": {
            "type": "number",
            "default": 0.5,
            "minimum": 0,
            "maximum": 1,
            "description": "Volume level for the terminal sound (0.0 to 1.0)"
          },
          "bugHorn.errorPatterns": {
            "type": "array",
            "default": [
              "error:",
              "Error:",
              "ERROR:",
              "fail:",
              "FAIL:",
              "Failed",
              "fatal:",
              "FATAL:",
              "Exception",
              "Traceback",
              "command not found",
              "No such file"
            ],
            "description": "Patterns to detect errors in terminal output"
          }
        }
      },
      "commands": [
        {
          "command": "bugHorn.toggle",
          "title": "Bug Horn: Toggle Error Sound"
        },
        {
          "command": "bugHorn.testSound",
          "title": "Bug Horn: Test Sound"
        },
        {
          "command": "bugHorn.addSound",
          "title": "Bug Horn: Add Custom Sound"
        },
        {
          "command": "bugHorn.openSoundsFolder",
          "title": "Bug Horn: Open Custom Sounds Folder"
        }
      ]
    },  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/node": "16.x",
    "eslint": "^8.41.0"
  }
}
